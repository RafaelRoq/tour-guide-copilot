# API — Option A: OpenAI (default)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.3

# API — Option B: local model via Ollama (no API key required)
# Install Ollama from https://ollama.com, then: ollama pull llama3.1:8b
# Uncomment the two lines below and comment out OPENAI_API_KEY above.
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.1:8b

# Content
GUIDE_LANGUAGE=en
GUIDE_NAME=Manolo
GUIDE_CITY=Madrid
GUIDE_YEARS=12 years as a guide
GUIDE_TIP_URL=https://paypal.me/example

# Output
OUTPUT_FORMAT=html

# Limits
# MAX_DOCUMENT_CHARS=400000    # ~100k tokens; raise if your guide has a very long document
